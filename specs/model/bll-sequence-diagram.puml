@startuml
title SongSpiration / MusicPin — Diagram sekwencji (tworzenie pinu)

actor User as user
participant "PinController" as controller
participant "PinService" as service
participant "PinRepository" as repository
participant "Mapper" as mapper

user -> controller: POST /pins (PinCreateDto)
activate controller

controller -> mapper: Map(PinCreateDto -> Pin)
activate mapper
mapper --> controller: Pin
deactivate mapper

controller -> service: CreatePin(Pin)
activate service

service -> mapper: Map(Pin -> PinEntity)
activate mapper
mapper --> service: PinEntity
deactivate mapper

service -> repository: Add(PinEntity)
activate repository
repository --> service: PinEntity
deactivate repository

service -> mapper: Map(PinEntity -> PinDto)
activate mapper
mapper --> service: PinDto
deactivate mapper

service --> controller: PinDto
deactivate service

controller --> user: 201 Created (PinDto)
deactivate controller

@enduml