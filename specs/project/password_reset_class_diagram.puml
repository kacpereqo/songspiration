@startuml Password Reset Class Diagram

class AuthToken {
    + Id : Guid
    + UserId : Guid
    + TokenHash : string
    + TokenType : TokenType
    + ExpiryDate : DateTime
    + IsRevoked : bool
}

enum TokenType {
    PasswordReset
    RefreshToken
    EmailVerification
}

class User {
    + Id : Guid
    + Email : string
    + PasswordHash : string
    ...
}

class ForgotPasswordDto {
    + Email : string
}

class ResetPasswordDto {
    + Token : string
    + NewPassword : string
}

interface IUserService {
    + ForgotPasswordAsync(dto: ForgotPasswordDto) : Task
    + ResetPasswordAsync(dto: ResetPasswordDto) : Task
}

class UserService {
    - _userRepository : IUserRepository
    - _dbContext : SongSpirationDbContext
    - _emailSender : IEmailSender
    + ForgotPasswordAsync(dto: ForgotPasswordDto) : Task
    + ResetPasswordAsync(dto: ResetPasswordDto) : Task
}

interface IEmailSender {
    + SendEmailAsync(to: string, subject: string, htmlMessage: string) : Task
}

User "1" *-- "0..*" AuthToken : Has
AuthToken "1" o-- "1" TokenType : Defines type
UserService ..> ForgotPasswordDto : Uses
UserService ..> ResetPasswordDto : Uses
UserService ..> IUserService : Implements
UserService --> IEmailSender : Uses
UserService --> AuthToken : Manages

@enduml